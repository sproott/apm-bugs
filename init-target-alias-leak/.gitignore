# Scenarios nest one level deeper than the repo-root .gitignore patterns reach.
# apm.yml here is generated by `apm init` -- it is the artifact under test, so it
# is regenerated rather than checked in. The .gitignore inside each scenario is
# written by `apm install`.
*/apm.yml
*/apm.lock.yaml
*/apm_modules/
*/.gitignore
*/.claude/
*/.github/
